{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$anchor": "userroles",
  "description": "Extra user properties for specifying roles",
  "$patch": {
    "source": { "$ref": "user" },
    "with": {
      "properties": {
        "roles": {
          "title": "Role",
          "description": "Roles assigned to this user",
          "type": "array",
          "items": {
            "type": "string",
            "isObjectId": true
          },
          "default": [],
          "_adapt": {
            "inputType": "Roles"
          }
        }
      }
    }
  }
}
